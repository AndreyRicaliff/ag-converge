{
  "buildCommand": "echo 'static site — no build'",
  "outputDirectory": ".",
  "installCommand": "echo skip",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ]
}
